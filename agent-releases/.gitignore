# Published Android Agent APK for ops download.
#
# Refresh locally:
#   bash ops/m0/stage-apks.sh
#   bash ops/m0/publish-agent-release.sh
#
# On the server, sync this directory to /opt/loanagent/agent-releases
# (APKs mounted read-only into control-plane; update-manifests/ is a writable overlay
# so Ops can POST signed manifests).
*.apk
*.pdf
latest.json
!update-manifests/.gitkeep
