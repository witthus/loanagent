# Local development only. Copy to .env and replace these values.
POSTGRES_DB=loanagent
POSTGRES_USER=loanagent
POSTGRES_PASSWORD=dev-only-postgres

EMQX_DASHBOARD_USER=admin
EMQX_DASHBOARD_PASSWORD=dev-only-emqx
EMQX_NODE_COOKIE=dev-only-emqx-cookie

# Control plane auth (also used by compose.server / debug Agent)
OPS_TOKEN=dev-only-ops-token
DEVICE_TOKEN=dev-only-device-token

# Server-owned task timeout policy (seconds; no per-task override)
TASK_QUEUE_TIMEOUT_SEC=300
TASK_EXECUTION_TIMEOUT_SEC=900
TASK_EFFECT_REPORT_GRACE_SEC=60
TASK_TIMEOUT_SCAN_INTERVAL_SEC=30
TASK_RESULT_PAYLOAD_MAX_BYTES=1048576

# Only enable when a trusted reverse proxy sits in front of control-plane.
# TRUST_PROXY_HEADERS=1
# TRUSTED_PROXIES=10.0.0.0/8,192.168.0.0/16

# M2a content/media (local filesystem + HMAC signed download URLs)
MEDIA_ROOT=/tmp/loanagent-media
MEDIA_SIGNING_SECRET=dev-only-media-signing-secret
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Server deploy only (infra/compose.server.yaml)
# AGENT_RELEASE_DIR=/app/agent-releases

# Optional comma-separated override for sensitive-word scanner
# SENSITIVE_WORDS=无抵押,秒贷,套现
