{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loanagent.local/schemas/task-record.schema.json",
  "title": "Persisted Task Record",
  "description": "Canonical control-plane/API representation of a persisted task. This is distinct from the downstream task command contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "task_id",
    "operation_id",
    "device_id",
    "account_id",
    "playbook",
    "params",
    "effect_class",
    "effect_committed",
    "status",
    "reconcile_required",
    "priority",
    "timeout_sec",
    "source",
    "error_code",
    "created_at",
    "updated_at",
    "accepted_at",
    "executing_at",
    "effect_committed_at",
    "reported_at",
    "terminal_at",
    "timeout_phase"
  ],
  "properties": {
    "schema_id": {
      "const": "task-record"
    },
    "schema_version": {
      "const": "1.0"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "device_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "playbook": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*@[0-9]+\\.[0-9]+$"
    },
    "params": {
      "type": "object"
    },
    "effect_class": {
      "enum": [
        "readonly",
        "idempotent",
        "non_idempotent"
      ]
    },
    "effect_committed": {
      "type": "boolean"
    },
    "status": {
      "enum": [
        "queued",
        "accepted",
        "executing",
        "effect_committed",
        "reported",
        "succeeded",
        "failed",
        "cancelled",
        "unknown",
        "reconcile_required"
      ]
    },
    "reconcile_required": {
      "type": "boolean"
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "timeout_sec": {
      "type": "integer",
      "minimum": 1
    },
    "source": {
      "enum": [
        "scheduler",
        "agent",
        "manual"
      ]
    },
    "error_code": {
      "anyOf": [
        {
          "$ref": "#/$defs/errorCode"
        },
        {
          "type": "null"
        }
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "accepted_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "executing_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "effect_committed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "reported_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "terminal_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "timeout_phase": {
      "enum": [
        "queued",
        "execution",
        "report",
        null
      ]
    }
  },
  "$defs": {
    "errorCode": {
      "description": "Stable extensible error identifier in UPPER_SNAKE_CASE. Producers may add codes without a schema revision while preserving this format.",
      "type": "string",
      "minLength": 2,
      "maxLength": 64,
      "pattern": "^[A-Z][A-Z0-9]*(?:_[A-Z0-9]+)*$",
      "examples": [
        "OPERATOR_CANCELLED",
        "DEVICE_OFFLINE_CANCELLED",
        "NAV_MISSING_HINT",
        "TIMEOUT",
        "EFFECT_UNKNOWN"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "unknown"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "reconcile_required": {
            "const": true
          },
          "error_code": {
            "const": "EFFECT_UNKNOWN"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "reconcile_required"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "reconcile_required": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "effect_committed": {
            "const": true
          }
        },
        "required": [
          "effect_committed"
        ]
      },
      "then": {
        "properties": {
          "status": {
            "enum": [
              "effect_committed",
              "reported",
              "succeeded",
              "failed",
              "unknown",
              "reconcile_required"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "effect_committed"
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "properties": {
          "effect_committed": {
            "const": true
          }
        }
      }
    }
  ]
}
