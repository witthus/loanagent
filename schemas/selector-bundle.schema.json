{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loanagent.local/schemas/selector-bundle.schema.json",
  "title": "Signed selector bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_version",
    "target_package",
    "target_app_versions",
    "selectors",
    "issued_at",
    "signature"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[1-9][0-9]*\\.[0-9]+$"
    },
    "bundle_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "target_package": {
      "type": "string",
      "minLength": 1
    },
    "target_app_versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "selectors": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/selector"
      }
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "value"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "Ed25519",
            "ECDSA-P256-SHA256"
          ]
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "value"
      ],
      "properties": {
        "strategy": {
          "enum": [
            "view_id",
            "text",
            "content_description",
            "class_name"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        },
        "exact": {
          "type": "boolean"
        }
      }
    }
  }
}
